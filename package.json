{
	"name": "obsidian-tagfolder",
	"version": "0.18.19",
	"description": "Show tags as folder.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node --env-file=.env esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"lint": "eslint .",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"svelte-check": "svelte-check --tsconfig ./tsconfig.json",
		"tsc-check": "tsc --noEmit",
		"check:e2e:obsidian": "tsc -p test/e2e-obsidian/tsconfig.json",
		"prepare:e2e:obsidian": "tsx test/e2e-obsidian/install-obsidian.mts",
		"test:e2e:obsidian:new-note-template": "npm run build && npm run prepare:e2e:obsidian && tsx test/e2e-obsidian/new-note-template.mts",
		"test:e2e:obsidian:note-lookup": "npm run build && npm run prepare:e2e:obsidian && tsx test/e2e-obsidian/note-lookup.mts",
		"check": "npm run lint && npm run test && npm run svelte-check && npm run tsc-check",
		"version": "node version-bump.mjs"
	},
	"keywords": [],
	"author": "vorotamoroz",
	"license": "MIT",
	"devDependencies": {
		"@emnapi/core": "1.11.2",
		"@emnapi/runtime": "1.11.2",
		"@eslint/js": "^9.39.1",
		"@tsconfig/svelte": "^5.0.4",
		"@types/node": "^22.20.1",
		"@typescript-eslint/parser": "^8.48.1",
		"@vitest/coverage-v8": "^4.1.9",
		"@vrtmrz/obsidian-test-session": "0.1.0",
		"esbuild": "^0.28.1",
		"esbuild-svelte": "^0.9.3",
		"eslint": "^9.39.1",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"eslint-plugin-svelte": "^3.13.0",
		"globals": "^14.0.0",
		"jsdom": "^29.1.1",
		"obsidian": "^1.10.3",
		"playwright": "^1.61.1",
		"svelte": "^5.45.5",
		"svelte-check": "^4.3.4",
		"svelte-eslint-parser": "^1.8.0",
		"svelte-preprocess": "^6.0.3",
		"terser": "^5.44.1",
		"tsx": "^4.23.0",
		"typescript": "^5.9.3",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@vrtmrz/obsidian-plugin-kit": "0.1.1",
		"@vrtmrz/ui-interactions": "0.1.0"
	}
}
